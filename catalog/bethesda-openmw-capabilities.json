  "sources": [
    {
      "label": "OpenMW downloads page",
      "url": "https://openmw.org/downloads/",
      "summary": "As of 2026-07-05, the latest official release listed by OpenMW is 0.51.0."
    },
    {
      "label": "OpenMW 0.51.0 release notes",
      "url": "https://openmw.org/2026/openmw-0-51-0-released/",
      "summary": "Released 2026-06-19. Focused on OpenMW scripting, editor terrain vertex painting, Lua crash fixes, gamepad menu fixes, and Morrowind-facing improvements."
    },
    {
      "label": "OpenMW 0.49.0 release notes",
      "url": "https://openmw.org/2025/openmw-0-49-0-released/",
      "summary": "Introduced prototype support for Oblivion, Skyrim, Fallout 3, Fallout: New Vegas, and Fallout 4 as very basic walking-simulator functionality."
    },
    {
      "label": "OpenMW 0.50.0 release notes",
      "url": "https://openmw.org/2025/openmw-0-50-0-released/",
      "summary": "Improved beyond-Morrowind terrain texturing and distant object rendering."
    },
    {
      "label": "OpenMW 0.50.0 release notes",
      "url": "https://openmw.org/2025/openmw-0-50-0-released/",
      "summary": "Improved beyond-Morrowind terrain texturing and distant object rendering."
    }
  ],
  "supportTiers": {
    "full": "Playable in OpenMW as a game/runtime.",
    "walking-sim": "World/cell loading is realistic; gameplay, actors, quests, scripts, and animation are partial or missing.",
    "asset-research": "Archives or assets may be inspectable, but a connected world viewer is not a clean target yet.",
    "future-research": "Not currently supported enough for the world picker."
  },
