{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nikami.local/schemas/fnv-actor-parity-sidecar.schema.json",
  "title": "Fallout New Vegas retail/OpenMW actor parity sidecar capture plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "sequenceId", "scene", "actions", "openMw", "actors"],
  "properties": {
    "schema": { "const": "nikami-fnv-actor-parity-sidecar/v1" },
    "sequenceId": {
      "description": "ASCII transport token. The coordinator additionally enforces the NKSC 127-byte UTF-8 header bound.",
      "type": "string",
      "minLength": 1,
      "maxLength": 127,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "scene": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cell", "camera", "time", "weather"],
      "properties": {
        "cell": { "type": "string", "minLength": 1 },
        "camera": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "stateId", "shotKind", "proofAnchorFormId", "targetPosition",
            "targetYawRadians", "playerPosition", "fullBodyDistanceScale",
            "minimumCameraHeight", "minimumAimHeight", "initializationFrames",
            "targetSettleFrames"
          ],
          "properties": {
            "stateId": { "type": "string", "minLength": 1 },
            "shotKind": { "const": "front-full-body" },
            "proofAnchorFormId": { "$ref": "#/$defs/retailFormId" },
            "targetPosition": { "$ref": "#/$defs/vector3" },
            "targetYawRadians": { "type": "number" },
            "playerPosition": { "$ref": "#/$defs/vector3" },
            "fullBodyDistanceScale": { "type": "number", "minimum": 1.25, "maximum": 10 },
            "minimumCameraHeight": { "type": "number", "minimum": 0 },
            "minimumAimHeight": { "type": "number", "minimum": 0 },
            "initializationFrames": { "type": "integer", "minimum": 1, "maximum": 1200 },
            "targetSettleFrames": { "type": "integer", "minimum": 1, "maximum": 600 }
          }
        },
        "time": {
          "type": "object",
          "additionalProperties": false,
          "required": ["gameHour", "timeScale"],
          "properties": {
            "gameHour": { "type": "number", "minimum": 0, "exclusiveMaximum": 24 },
            "timeScale": { "type": "number", "minimum": 0, "maximum": 10000 }
          }
        },
        "weather": {
          "type": "object",
          "additionalProperties": false,
          "required": ["editorId", "retailFormId", "openMwId"],
          "properties": {
            "editorId": { "type": "string", "minLength": 1 },
            "retailFormId": { "$ref": "#/$defs/retailFormId" },
            "openMwId": { "$ref": "#/$defs/openMwFormId" }
          }
        }
      }
    },
    "actions": {
      "description": "Arbitrary nonempty ordered transport descriptors. Engine group names request playback only and do not prove observed animation or visual parity.",
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/action" }
    },
    "openMw": {
      "type": "object",
      "additionalProperties": false,
      "required": ["representativeOffset"],
      "properties": {
        "representativeOffset": { "type": "integer", "minimum": 0 }
      }
    },
    "actors": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8192,
      "items": { "$ref": "#/$defs/actor" }
    }
  },
  "$defs": {
    "retailFormId": { "type": "string", "pattern": "^0[xX][0-9a-fA-F]{1,8}$" },
    "openMwFormId": { "type": "string", "pattern": "^(FormId|formid):0[xX][0-9a-fA-F]{1,8}$" },
    "appearance": {
      "description": "Post-frame actor appearance evidence. Endpoint-specific diagnostic fields remain allowed, but render-part parity uses only the generic fields declared here.",
      "type": "object",
      "additionalProperties": true,
      "required": ["renderParts"],
      "properties": {
        "renderParts": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/renderPart" }
        }
      }
    },
    "renderPart": {
      "description": "One post-frame render part. role/sourceFormId/sourceSlot/ordinal is its stable cross-engine identity; addresses and traversal order are diagnostics only.",
      "type": "object",
      "additionalProperties": true,
      "required": [
        "role", "sourceFormId", "sourceSlot", "ordinal", "required",
        "attached", "drawable", "visible", "textureBindings"
      ],
      "properties": {
        "role": { "type": "string", "minLength": 1 },
        "sourceFormId": {
          "oneOf": [
            { "$ref": "#/$defs/retailFormId" },
            { "$ref": "#/$defs/openMwFormId" },
            { "type": "integer", "minimum": 0, "maximum": 4294967295 }
          ]
        },
        "sourceSlot": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "ordinal": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "required": { "type": "boolean" },
        "attached": { "type": "boolean" },
        "drawable": { "type": "boolean" },
        "visible": { "type": "boolean" },
        "alphaBits": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "materialId": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "integer", "minimum": 0, "maximum": 4294967295 }
          ]
        },
        "shaderId": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "integer", "minimum": 0, "maximum": 4294967295 }
          ]
        },
        "modelHash": { "type": "string", "minLength": 1 },
        "nodeHash": { "type": "string", "minLength": 1 },
        "textureBindings": {
          "type": "array",
          "items": { "$ref": "#/$defs/textureBinding" }
        }
      }
    },
    "textureBinding": {
      "description": "One resolved texture semantic. semantic/stage is stable identity and path comparison uses coordinator normalization.",
      "type": "object",
      "additionalProperties": true,
      "required": [
        "semantic", "path", "contentHash", "width", "height", "format",
        "sourceKind", "stage"
      ],
      "properties": {
        "semantic": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "contentHash": { "type": "string", "minLength": 1 },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "format": { "type": "string", "minLength": 1 },
        "sourceKind": {
          "type": "string",
          "enum": ["authored", "generated", "runtime", "fallback", "neutral"]
        },
        "stage": { "type": "integer", "minimum": 0 }
      }
    },
    "vector3": {
      "type": "array",
      "prefixItems": [{ "type": "number" }, { "type": "number" }, { "type": "number" }],
      "minItems": 3,
      "maxItems": 3
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "openMwPoseGroup", "retailPlayGroup", "frames"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,126}$" },
        "openMwPoseGroup": { "type": "string", "pattern": "^[A-Za-z0-9_.-]{1,127}$" },
        "retailPlayGroup": { "type": "string", "pattern": "^[A-Za-z0-9_]{1,63}$" },
        "frames": { "type": "integer", "minimum": 1, "maximum": 36000 }
      }
    },
    "weapon": {
      "type": "object",
      "additionalProperties": false,
      "required": ["editorId", "formId"],
      "properties": {
        "editorId": { "type": ["string", "null"] },
        "formId": {
          "oneOf": [{ "$ref": "#/$defs/retailFormId" }, { "type": "null" }]
        }
      }
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "captureIndex", "openMwRepresentativeIndex", "actorFormId", "actorBaseId",
        "openMwBaseId", "selectedMainWeapon"
      ],
      "properties": {
        "captureIndex": { "type": "integer", "minimum": 0 },
        "openMwRepresentativeIndex": { "type": "integer", "minimum": 0 },
        "actorFormId": { "$ref": "#/$defs/retailFormId" },
        "actorBaseId": { "$ref": "#/$defs/retailFormId" },
        "openMwBaseId": { "$ref": "#/$defs/openMwFormId" },
        "editorId": { "type": "string" },
        "displayName": { "type": "string" },
        "visualTypeKey": {
          "description": "Optional roster diagnostic only; it is not used to infer actor identity or parity.",
          "type": "string",
          "minLength": 1
        },
        "selectedMainWeapon": { "$ref": "#/$defs/weapon" },
        "enableParentFormId": {
          "oneOf": [{ "$ref": "#/$defs/retailFormId" }, { "type": "null" }]
        }
      }
    }
  }
}
