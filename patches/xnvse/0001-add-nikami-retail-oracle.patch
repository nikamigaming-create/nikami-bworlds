+    bool setWeaponOutUnsafe(Actor* actor)
+    {
+        bool succeeded = false;
+        __try
+        {
+            actor->baseProcess->SetWeaponOut(actor, true);
+            succeeded = true;
+        }
+        __except (EXCEPTION_EXECUTE_HANDLER)
+        {
+            succeeded = false;
+        }
+        return succeeded;
+    }
