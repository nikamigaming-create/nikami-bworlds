+            << ",\"completed\":" << ((quest->flags & 0x02) != 0 ? "true" : "false")
+            << ",\"shownInPipBoy\":" << ((quest->flags & 0x20) != 0 ? "true" : "false")
+            << ",\"failed\":" << ((quest->flags & 0x40) != 0 ? "true" : "false")
