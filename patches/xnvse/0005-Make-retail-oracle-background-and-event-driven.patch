+                    if (i != 0)
+                        gOutput << ',';
+                    const bool accepted = gConsole != nullptr
+                        && gConsole->RunScriptLine2(gFurnitureSettledCommands[i].c_str(), nullptr, true);
+                    gOutput << "{\"text\":" << jsonString(gFurnitureSettledCommands[i].c_str())
+                            << ",\"accepted\":" << (accepted ? "true" : "false") << '}';
