From f8863dd47a608c5534d1a89dc6d1584b4c79fd12 Mon Sep 17 00:00:00 2001
From: Nikami Creative <295006744+nikamigaming-create@users.noreply.github.com>
Date: Sun, 12 Jul 2026 16:44:19 -0700
Subject: [PATCH] Execute Fallout HDR blend and bloom

---
 apps/openmw/mwrender/postprocessor.cpp        |   5 +-
 apps/openmw/mwrender/postprocessor.hpp        |   4 +-
 apps/openmw/mwworld/weather.cpp               |   6 ++
 .../shaders/internal_fallout_imagespace.omwfx | 101 +++++++++++++++++-
 4 files changed, 110 insertions(+), 6 deletions(-)

diff --git a/apps/openmw/mwrender/postprocessor.cpp b/apps/openmw/mwrender/postprocessor.cpp
index 34a24d1152..b4a726fd2f 100644
--- a/apps/openmw/mwrender/postprocessor.cpp
+++ b/apps/openmw/mwrender/postprocessor.cpp
@@ -287,8 +287,8 @@ namespace MWRender
         mRendering.getSkyManager()->setSunglare(true);
     }
 
-    void PostProcessor::setFalloutImageSpace(
-        const osg::Vec4f& cinematic, const osg::Vec4f& tint, const osg::Vec4f& fade)
+    void PostProcessor::setFalloutImageSpace(const osg::Vec4f& hdr, const osg::Vec4f& cinematic,
+        const osg::Vec4f& tint, const osg::Vec4f& fade)
     {
         if (!mFalloutImageSpaceTechnique)
         {
@@ -299,6 +299,7 @@ namespace MWRender
             enable();
         }
 
+        setUniform(mFalloutImageSpaceTechnique, "uFalloutHdr", hdr);
         setUniform(mFalloutImageSpaceTechnique, "uFalloutCinematic", cinematic);
         setUniform(mFalloutImageSpaceTechnique, "uFalloutTint", tint);
         setUniform(mFalloutImageSpaceTechnique, "uFalloutFade", fade);
diff --git a/apps/openmw/mwrender/postprocessor.hpp b/apps/openmw/mwrender/postprocessor.hpp
index 9dac7ae79b..d6dabb8d7f 100644
--- a/apps/openmw/mwrender/postprocessor.hpp
+++ b/apps/openmw/mwrender/postprocessor.hpp
@@ -174,8 +174,8 @@ namespace MWRender
 
         void setUnderwaterFlag(bool underwater) { mUnderwater = underwater; }
 
-        void setFalloutImageSpace(
-            const osg::Vec4f& cinematic, const osg::Vec4f& tint, const osg::Vec4f& fade);
+        void setFalloutImageSpace(const osg::Vec4f& hdr, const osg::Vec4f& cinematic,
+            const osg::Vec4f& tint, const osg::Vec4f& fade);
 
         void toggleMode();
 
diff --git a/apps/openmw/mwworld/weather.cpp b/apps/openmw/mwworld/weather.cpp
index 7939e79ac9..b809d610d9 100644
--- a/apps/openmw/mwworld/weather.cpp
+++ b/apps/openmw/mwworld/weather.cpp
@@ -1049,6 +1049,12 @@ namespace MWWorld
                 mResult.mSunColor[component] *= sunlightDimmer;
 
             mRendering.getPostProcessor()->setFalloutImageSpace(
+                osg::Vec4f(composed.mTraits[ESM4::ImageSpace::Trait_TargetLuminance],
+                    composed.mTraits[ESM4::ImageSpace::Trait_BrightScale],
+                    composed.mTraits[ESM4::ImageSpace::Trait_BrightClamp],
+                    player.getCell()->isExterior()
+                        ? composed.mTraits[ESM4::ImageSpace::Trait_BloomAlphaExterior]
+                        : composed.mTraits[ESM4::ImageSpace::Trait_BloomAlphaInterior]),
                 osg::Vec4f(composed.mTraits[ESM4::ImageSpace::Trait_CinematicSaturation],
                     composed.mTraits[ESM4::ImageSpace::Trait_CinematicContrastAverageLuminance],
                     composed.mTraits[ESM4::ImageSpace::Trait_CinematicContrast],
diff --git a/files/data/shaders/internal_fallout_imagespace.omwfx b/files/data/shaders/internal_fallout_imagespace.omwfx
index 10358ba3cc..8cb6625d40 100644
--- a/files/data/shaders/internal_fallout_imagespace.omwfx
+++ b/files/data/shaders/internal_fallout_imagespace.omwfx
@@ -1,3 +1,8 @@
+uniform_vec4 uFalloutHdr {
+    default = vec4(1.0, 0.0, 1.0, 1.0);
+    static = false;
+}
+
 uniform_vec4 uFalloutCinematic {
     default = vec4(1.0, 0.0, 1.0, 1.0);
     static = false;
@@ -13,7 +18,87 @@ uniform_vec4 uFalloutFade {
     static = false;
 }
 
-fragment main {
+render_target RT_FalloutBright {
+    width_ratio = 0.25;
+    height_ratio = 0.25;
+    internal_format = rgb16f;
+    source_type = half_float;
+    source_format = rgb;
+    mipmaps = false;
+    min_filter = linear;
+    mag_filter = linear;
+}
+
+render_target RT_FalloutBlurX {
+    width_ratio = 0.25;
+    height_ratio = 0.25;
+    internal_format = rgb16f;
+    source_type = half_float;
+    source_format = rgb;
+    mipmaps = false;
+    min_filter = linear;
+    mag_filter = linear;
+}
+
+render_target RT_FalloutBloom {
+    width_ratio = 0.25;
+    height_ratio = 0.25;
+    internal_format = rgb16f;
+    source_type = half_float;
+    source_format = rgb;
+    mipmaps = false;
+    min_filter = linear;
+    mag_filter = linear;
+}
+
+fragment bright(target=RT_FalloutBright) {
+    omw_In vec2 omw_TexCoord;
+
+    void main()
+    {
+        vec3 source = omw_GetLastShader(omw_TexCoord).rgb;
+        vec3 brightColor = max(source - vec3(uFalloutHdr.z), vec3(0.0));
+        omw_FragColor = vec4(brightColor * uFalloutHdr.y * uFalloutHdr.w, 1.0);
+    }
+}
+
+fragment blur_x(target=RT_FalloutBlurX, rt1=RT_FalloutBright) {
+    omw_In vec2 omw_TexCoord;
+
+    void main()
+    {
+        vec3 color = vec3(0.0);
+        float weight = 0.0;
+        for (int i = -4; i <= 4; ++i)
+        {
+            float w = exp(-0.5 * float(i * i) / 4.0);
+            color += omw_Texture2D(RT_FalloutBright,
+                omw_TexCoord + vec2(float(i) / (omw.resolution.x * 0.25), 0.0)).rgb * w;
+            weight += w;
+        }
+        omw_FragColor = vec4(color / weight, 1.0);
+    }
+}
+
+fragment blur_y(target=RT_FalloutBloom, rt1=RT_FalloutBlurX) {
+    omw_In vec2 omw_TexCoord;
+
+    void main()
+    {
+        vec3 color = vec3(0.0);
+        float weight = 0.0;
+        for (int i = -4; i <= 4; ++i)
+        {
+            float w = exp(-0.5 * float(i * i) / 4.0);
+            color += omw_Texture2D(RT_FalloutBlurX,
+                omw_TexCoord + vec2(0.0, float(i) / (omw.resolution.y * 0.25))).rgb * w;
+            weight += w;
+        }
+        omw_FragColor = vec4(color / weight, 1.0);
+    }
+}
+
+fragment final(rt1=RT_FalloutBloom) {
     omw_In vec2 omw_TexCoord;
 
     void main()
@@ -21,6 +106,17 @@ fragment main {
         vec4 source = omw_GetLastShader(omw_TexCoord);
         vec3 color = source.rgb;
 
+        // ISHDRBLENDINSHADER*.pso: the unblurred scene contribution is
+        // normalized by twice the greater of scene alpha and the authored
+        // target luminance. OpenMW's intercepted scene is already LDR-scaled,
+        // unlike retail's HDR source; the measured LDR-equivalent source
+        // coefficient is 2/3 rather than retail's 1/2. Keep this conversion
+        // at the buffer boundary instead of baking a grade into actor assets.
+        float hdrDenominator = max(max(source.a, uFalloutHdr.x), 0.01);
+        color = max(color / (1.5 * hdrDenominator), vec3(0.0));
+        color += omw_Texture2D(RT_FalloutBloom, omw_TexCoord).rgb
+            * (uFalloutHdr.x / hdrDenominator);
+
         // ISHDRBLENDINSHADERCIN.pso, package 13: luminance/saturation,
         // weighted tint, then brightness/contrast about average luminance.
         float luminance = dot(color, vec3(0.299, 0.587, 0.114));
@@ -38,6 +134,7 @@ technique {
     description = "Internal Fallout 3/New Vegas image-space cinematic stage";
     version = "1.0";
     author = "OpenMW Fallout compatibility overlay";
-    passes = main;
+    passes = bright, blur_x, blur_y, final;
     flags = hidden;
+    hdr = true;
 }
-- 
