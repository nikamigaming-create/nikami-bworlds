+                             << boneOffsetLocalOrigin.y() << "," << boneOffsetLocalOrigin.z() << ")"
+                             << " boneOffsetWorldOrigin=(" << boneOffsetWorldOrigin.x() << ","
+                             << boneOffsetWorldOrigin.y() << "," << boneOffsetWorldOrigin.z() << ")"
+                             << " attachWorldOrigin=(" << attachWorldOrigin.x() << "," << attachWorldOrigin.y()
+                             << "," << attachWorldOrigin.z() << ")"
+                             << " partWorldOrigin=(" << partWorldOrigin.x() << "," << partWorldOrigin.y() << ","
+                             << partWorldOrigin.z() << ")"
+                             << " runtime=measurement-only gate=runtime-fnv-part-attachment-matrix";
+        }
         forceWorldViewerActorPartMask(attached.get(), correctedModel.value(), mPtr);
