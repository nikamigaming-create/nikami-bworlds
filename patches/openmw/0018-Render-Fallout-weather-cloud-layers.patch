+                                         << " color=(" << formatVec4(mFalloutCloudColours[layer]) << ") visible="
+                                         << (mFalloutCloudLayerNodes[layer]
+                                                && mFalloutCloudLayerNodes[layer]->getNodeMask());
+                    }
+                    loggedCloudLayers = true;
+                }
+            }
+        }
