+            mFo4ProceduralPoseBones.reserve(nodes.size());
+            for (osg::MatrixTransform* node : nodes)
+                mFo4ProceduralPoseBones.push_back({ node, getNodeWorldMatrix(node) * rootInverse });
+            mFo4ProceduralPoseInitialized = true;
