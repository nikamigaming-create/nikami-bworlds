+                result.mError = preError;
+                result.mOrder = "pre";
+            }
+            else
+            {
+                setFalloutIkTransformWorldMatrix(
+                    bone, osg::Matrix::rotate(postRotation) * osg::Matrix::translate(boneOrigin));
+                result.mError = postError;
+                result.mOrder = "post";
+            }
