+            colors->push_back(osg::Vec4f(0.f, 0.4f, 1.f, 1.f));
+            geometry->setColorArray(colors, osg::Array::BIND_PER_VERTEX);
+            geometry->addPrimitiveSet(new osg::DrawArrays(osg::PrimitiveSet::LINES, 0, vertices->size()));
