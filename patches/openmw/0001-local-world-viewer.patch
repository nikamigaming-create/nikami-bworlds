+            && leftUpperArm > 5.f && leftUpperArm < 42.f && leftForearm > 5.f && leftForearm < 42.f
+            && rightUpperArm > 5.f && rightUpperArm < 42.f && rightForearm > 5.f && rightForearm < 42.f
