+            if ((!flatMaterials && !fullbrightMaterials) || node == nullptr)
+                return;
+
+            const std::string lowered = Misc::StringUtils::lowerCase(path.value());
+            const bool actorPath = isWorldViewerActorMeshPath(lowered);
