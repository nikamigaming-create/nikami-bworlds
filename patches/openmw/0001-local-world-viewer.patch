+
+            osg::ref_ptr<osg::ShapeDrawable> origin = new osg::ShapeDrawable(new osg::Sphere(osg::Vec3f(),
+                getPointerDebugEnvFloat("OPENMW_FNV_VR_POINTER_ORIGIN_RADIUS", 5.f)));
