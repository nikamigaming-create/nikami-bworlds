+    bool worldViewerStaticCameraRequested()
+    {
+        const char* value = std::getenv("OPENMW_WORLD_VIEWER_START_CAMERA_MODE");
+        return value != nullptr && (std::string(value) == "static" || std::string(value) == "orbit-raycast");
+    }
