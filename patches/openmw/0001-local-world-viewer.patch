+    std::string worldViewerOsgObjectType(const osg::Object& object)
+    {
+        std::string type = object.libraryName();
+        if (!type.empty())
+            type += "::";
+        type += object.className();
+        return cleanWorldViewerTelemetryString(type);
+    }
