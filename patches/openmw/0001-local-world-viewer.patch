+                         << " rgbNonzero=" << stats.hasNonZeroRgb() << " rgbVarying=" << stats.hasVaryingRgb()
+                         << " min=" << (stats.mSamples == 0 ? "none" : formatVec4(stats.mMin))
+                         << " max=" << (stats.mSamples == 0 ? "none" : formatVec4(stats.mMax));
+    }
