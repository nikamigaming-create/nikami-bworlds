+            frameSamples.push_back(focus - right * frameSide);
+            frameSamples.push_back(focus + osg::Vec3f(0.f, 0.f, frameUp));
+            frameSamples.push_back(focus - osg::Vec3f(0.f, 0.f, frameDown));
