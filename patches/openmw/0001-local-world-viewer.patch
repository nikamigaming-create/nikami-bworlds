+    std::string cleanWorldViewerTelemetryString(std::string value)
+    {
+        for (char& c : value)
+        {
+            if (c == '"')
+                c = '\'';
+            else if (static_cast<unsigned char>(c) < 32)
+                c = ' ';
+        }
+        return value;
+    }
