+            colors->push_back(osg::Vec4f(1.f, 0.f, 0.f, 1.f));
+            colors->push_back(osg::Vec4f(1.f, 0.f, 0.f, 1.f));
+            colors->push_back(osg::Vec4f(0.f, 1.f, 0.f, 1.f));
