+
+    bool isWorldViewerActorPtr(const MWWorld::Ptr& ptr)
+    {
+        if (ptr.isEmpty())
+            return false;
+
+        try
+        {
+            return ptr.getClass().isActor();
+        }
+        catch (const std::exception&)
+        {
+            return false;
