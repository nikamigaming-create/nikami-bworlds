+                                                   : osg::Vec4f(0.78f, 0.83f, 0.76f, 1.f);
+                WorldViewerFlatTemplateVisitor visitor(color);
+                node->accept(visitor);
+                stateSets = visitor.mStateSets;
+                geometries = visitor.mGeometries;
