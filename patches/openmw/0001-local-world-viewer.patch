+                {
+                    continue;
+                }
+                if (!value)
+                    continue;
+
+                if (const float* amount = std::get_if<float>(&*value))
+                    return *amount;
+                if (const bool* pressed = std::get_if<bool>(&*value); pressed && *pressed)
+                    return 1.f;
